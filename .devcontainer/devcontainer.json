{
  "name": "ROS2 Humble",
  "build": {
    "dockerfile": "Dockerfile"
  },
  "workspaceMount": "source=${localWorkspaceFolder},target=/repo_root,type=bind",
  "workspaceFolder": "/repo_root",
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-iot.vscode-ros"
      ],
      "settings": {
        "python.defaultInterpreterPath": "/usr/bin/python3",
        "ros.distro": "humble",
        "terminal.integrated.cwd": "/repo_root/ros2_ws"
      }
    }
  },
  "postCreateCommand": "rosdep update && rosdep install --from-paths repo_root/ros2_ws/src --ignore-src -r -y"
}